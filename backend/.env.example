# Port configuration for the Express server
PORT=5000

# MongoDB Connection URI (e.g. MongoDB Atlas Connection String)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# Frontend Client URL & Allowed CORS Origins (Comma-separated list)
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Node environment setting (development / production)
NODE_ENV=development

# Clerk Authentication credentials (Connected in Phase 7)
CLERK_SECRET_KEY=sk_test_your_key_here
CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_WEBHOOK_SIGNING_SECRET=whsec_your_secret_here

# SAP Integration Mode (true = mock data simulation, false = live RFC connections)
SAP_MOCK_MODE=true

# Structured Winston logging level (error, warn, info, debug)
LOG_LEVEL=info

# Upload parameters
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
